{
  "info": {
    "name": "Email Marketing System API",
    "description": "API collection for the Email Marketing System backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@gmail.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Verify Login OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"challengeId\": \"uuid\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/verify-login-otp"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout"
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "Campaigns",
      "item": [
        {
          "name": "Get All Campaigns",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/campaigns"
          }
        },
        {
          "name": "Create Campaign",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"campaign_name\": \"Summer Sale\",\n  \"campaign_subject\": \"Big Discounts!\",\n  \"template_id\": 1,\n  \"contact_segment\": \"all\"\n}"
            },
            "url": "{{baseUrl}}/api/campaigns"
          }
        },
        {
          "name": "Send Campaign",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/campaigns/:id/send"
          }
        },
        {
          "name": "Track Open",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/campaigns/track/open/:trackingId"
          }
        },
        {
          "name": "Unsubscribe",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/campaigns/unsubscribe?email=user@example.com&campaign=1"
          }
        }
      ]
    },
    {
      "name": "Contacts",
      "item": [
        {
          "name": "Get All Contacts",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/contacts"
          }
        },
        {
          "name": "Add Contact",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"1234567890\"\n}"
            },
            "url": "{{baseUrl}}/api/contacts"
          }
        }
      ]
    },
    {
      "name": "Templates",
      "item": [
        {
          "name": "Get All Templates",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/templates"
          }
        },
        {
          "name": "Create Template",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Newsletter\",\n  \"subject\": \"Monthly Update\",\n  \"body\": \"Hello {{name}}, here is your update.\"\n}"
            },
            "url": "{{baseUrl}}/api/templates"
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Get Overview",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/analytics/overview"
          }
        },
        {
          "name": "Campaign Performance",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/analytics/campaigns/performance"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    }
  ]
}